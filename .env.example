# WuzAPI Configuration
WUZAPI_BASE_URL=http://localhost:7143
WUZAPI_TOKEN=your_user_token_here
WUZAPI_ADMIN_TOKEN=your_admin_token_here
WUZAPI_HISTORY_SYNC=true

# Privacy & Compliance (LGPD/GDPR)
# Set WUZAPI_PRIVACY_MODE=true to redact PII (CPF, Cards, Emails) from logs and responses
WUZAPI_PRIVACY_MODE=false

# Groq (free LLM for testing) — get your key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
