WUZAPI_BASE_URL=http://localhost:7143
WUZAPI_TOKEN=mcp_whatsapp_user_token
WUZAPI_ADMIN_TOKEN=mcp_whatsapp_user_admin_token
WUZAPI_HISTORY_SYNC=true
WUZAPI_PRIVACY_MODE=false

# Groq (gratuito) — obtenha em https://console.groq.com/keys
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...

# Modelo Groq. Opções recomendadas:
#   llama-3.1-8b-instant      = mais rápido, porém pode repetir chamadas de tools
#   llama-3.3-70b-versatile   = melhor qualidade, recomendado para agentes MCP
#   mixtral-8x7b-32768        = alternativa intermediária
# Lista completa: https://console.groq.com/docs/models
GROQ_MODEL=llama-3.1-8b-instant

# Modelo OpenAI. Opções recomendadas:
#   gpt-4o-mini   = mais barato, suficiente para testes
#   gpt-4o        = melhor qualidade
#   gpt-4.1       = mais recente
OPENAI_MODEL=gpt-4o-mini